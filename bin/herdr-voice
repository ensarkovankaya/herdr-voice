#!/usr/bin/env bash
set -euo pipefail
APP="$HOME/.herdr-voice"
CFG="$APP/config.json"
LOG="$APP/logs/herdr-voice.log"
LABEL="dev.herdr-voice"

die(){ echo "herdr-voice: $*" >&2; exit 1; }
[ -f "$CFG" ] || die "no config: $CFG (run install first)"
role(){ jq -r '.role // "host"' "$CFG"; }
provider(){ jq -r '.tts.provider // "say"' "$CFG"; }
lang(){ jq -r '.language // "en"' "$CFG"; }
# Resolve a spoken string: explicit config field wins, else the language pack.
# $1=config field, $2=English default, $3=Turkish default
hv_str(){
  local v; v=$(jq -r --arg k "$1" '.[$k] // empty' "$CFG")
  if [ -n "$v" ]; then printf '%s' "$v"
  else case "$(lang)" in tr) printf '%s' "$3" ;; *) printf '%s' "$2" ;; esac; fi
}

ROOT="${HERDR_VOICE_ROOT:-$APP}"
# shellcheck source=bin/lib/service.sh
. "$ROOT/bin/lib/service.sh" 2>/dev/null || . "$(dirname "$0")/lib/service.sh"

case "${1:-status}" in
  start)   svc_start; echo "started ($(role))" ;;
  stop)    svc_stop; echo "stopped" ;;
  restart) svc_restart; echo "restarted" ;;
  status)
    st="$(svc_status)"
    echo "herdr-voice: $st | role=$(role) | enabled=$(jq -r '.enabled // false' "$CFG") | provider=$(provider)"
    [ "$(role)" = "remote" ] && echo "last registration: $(grep -E 'REGISTER|DEREGISTER' "$LOG" 2>/dev/null | tail -1 || echo '-')"
    echo "--- recent log ---"; tail -n 10 "$LOG" 2>/dev/null || echo "(no log)" ;;
  logs)    tail -f "$LOG" ;;
  enable|disable)
    new=$([ "$1" = enable ] && echo true || echo false)
    tmp=$(mktemp); jq --argjson e "$new" '.enabled=$e' "$CFG" > "$tmp" && mv -f "$tmp" "$CFG"
    printf '[%s] [INFO] %s (cli)\n' "$(date -u +%FT%TZ)" "$([ "$new" = true ] && echo ENABLE || echo DISABLE)" >> "$LOG"
    msg=$([ "$new" = true ] && hv_str voiceOnText 'Voice on.' 'Ses açıldı.' || hv_str voiceOffText 'Voice off.' 'Ses kapandı.')
    HOST=$(jq -r '.host // "127.0.0.1"' "$CFG"); PORT=$(jq -r '.port // 8973' "$CFG"); TOK=$(jq -r '.token // ""' "$CFG")
    curl -fsS -X POST "http://$HOST:$PORT/speak" -H "X-Voice-Token: $TOK" -H 'Content-Type: application/json' \
      -d "$(jq -nc --arg t "$msg" '{text:$t}')" >/dev/null 2>&1 || true
    echo "enabled=$new" ;;
  uninstall)
    r="$(role)"
    if [ "${2:-}" != "--yes" ]; then
      extra=""; if [ "$r" = host ]; then extra=" + Claude hooks + herdr plugin"; fi
      printf "Remove herdr-voice? launchd + CLI + ~/.herdr-voice (incl. token)%s [y/N] " "$extra"
      read -r ans || ans=""
      case "$ans" in y|Y|yes) ;; *) echo "cancelled"; exit 0 ;; esac
    fi
    svc_uninstall
    if [ "$r" = host ]; then
      S="$HOME/.claude/settings.json"
      if [ -f "$S" ]; then
        tmp="$(mktemp)"
        jq '.hooks = (.hooks // {})
          | .hooks.Stop = ((.hooks.Stop // []) | map(select(((.hooks[]?.command) // "") | test("herdr?-voice") | not)))
          | .hooks.Notification = ((.hooks.Notification // []) | map(select(((.hooks[]?.command) // "") | test("herdr?-voice") | not)))' \
          "$S" > "$tmp" && mv -f "$tmp" "$S"
      fi
      herdr plugin uninstall herdr-voice >/dev/null 2>&1 || herdr plugin unlink herdr-voice >/dev/null 2>&1 || true
      echo "Note: remove the statusLine snippet and the herdr keybinds (prefix+shift+v, prefix+shift+p) by hand."
    fi
    rm -rf "$APP"
    rm -f "$HOME/.local/bin/herdr-voice"
    echo "herdr-voice removed (role=$r)." ;;
  *) die "usage: herdr-voice {start|stop|restart|status|logs|enable|disable|uninstall}" ;;
esac
