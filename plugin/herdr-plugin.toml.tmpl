id = "ensar.herd-voice"
name = "herd-voice"
version = "0.1.0"
min_herdr_version = "0.7.0"
description = "Speak Claude Code summaries on your active device (macOS say)."
platforms = ["macos"]

[[actions]]
id = "toggle"
title = "herd-voice: toggle voice (global)"
command = ["bash", "actions/toggle.sh"]

[[actions]]
id = "toggle-pane"
title = "herd-voice: toggle voice (this pane)"
command = ["bash", "actions/toggle.sh", "pane"]

[[actions]]
id = "enable"
title = "herd-voice: voice on"
command = ["bash", "actions/toggle.sh", "on"]

[[actions]]
id = "disable"
title = "herd-voice: voice off"
command = ["bash", "actions/toggle.sh", "off"]
